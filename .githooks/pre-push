#!/bin/bash
# Pre-push hook — lightweight workspace check only.
# Full test suite + audit runs in CI, not here.
# Pre-commit already runs fmt + clippy.
# See pre-push.full for the comprehensive version.

export PATH="$HOME/.cargo/bin:$PATH"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "\n${CYAN}[pre-push]${NC} Running cargo check --workspace..."

CHECK_OUTPUT=$(cargo check --workspace 2>&1)
if [ $? -ne 0 ]; then
    echo -e "${RED}[✗]${NC} Workspace check failed"
    echo "$CHECK_OUTPUT"
    exit 1
fi

echo -e "${GREEN}[✓]${NC} Workspace compiles — pushing."
exit 0
